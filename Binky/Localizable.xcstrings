    "%1$lld files sorted · %2$lld moves · %3$lld runs (last week). Tap Binky for the share card.": {
      "comment": "Weekly digest notification summary.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已整理 %1$lld 个文件 · %2$lld 次移动 · %3$lld 次运行（上周）。点击 Binky 获取分享卡片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld 檔案已排序 · %2$lld 移動 · %3$lld 運行（上週）。點擊 Binky 以取得共享卡。"
          }
        }
      }
    },
