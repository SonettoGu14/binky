          "stringUnit" : {
            "state" : "translated",
            "value" : "Скопируйте поддерживаемый файл в Finder или скопируйте изображение (PNG или TIFF), а затем повторите попытку."
          }
        },
        "tr" : {
          "stringUnit" : {
