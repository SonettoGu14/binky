    "You’re on Binky %@ — the latest.": {
      "comment": "Manual update: up to date; argument is version.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您正在使用 Binky %@ — 最新的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您正在使用 Binky %@ — 最新的。"
          }
        }
      }
    },
    "Your current results will be cleared when Binky relaunches.": {
      "comment": "Alert detail for install with queue.",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Binky 重新启动时，您当前的结果将被清除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Binky 重新啟動時，您目前的結果將會被清除。"
          }
        }
      }
    },
    "Your rules. Your Mac. No guessing.": {
